<?php

use PhpMx\Json;
use PhpMx\Terminal;
use PhpMx\Trait\TerminalInstallTrait;

return new class {

    use TerminalInstallTrait;

    function __invoke()
    {
        self::createDir('source/Controller');
        self::createDir('storage/assets');
        self::createDir('storage/download');
        self::createDir('system/middleware');
        self::createDir('system/router');

        self::blockFile('.env', 'MX-SERVER', [
            'FORCE_SSL = false'
        ]);

        $settings = Json::import('.vscode/settings.json');
        $settings['explorer.fileNesting.patterns'] = $settings['explorer.fileNesting.patterns'] ?? [];
        $settings['explorer.fileNesting.patterns']['index.php'] = ".htaccess";
        Json::export('.vscode/settings.json', $settings);
    }
};
